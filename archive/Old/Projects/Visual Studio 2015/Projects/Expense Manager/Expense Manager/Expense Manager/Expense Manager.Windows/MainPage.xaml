                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="stackPanel3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.2">
                    <DiscreteObjectKeyFrame.Value>
                        <Visibility>Visible</Visibility>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="stackPanel3">
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)" Storyboard.TargetName="stackPanel3">
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="-60"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="toggleButton">
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="watermarkTextBox1">
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.IsHitTestVisible)" Storyboard.TargetName="toggleButton">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <x:Boolean>True</x:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="grid6">
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.IsHitTestVisible)" Storyboard.TargetName="grid6">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <x:Boolean>True</x:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.IsHitTestVisible)" Storyboard.TargetName="watermarkTextBox1">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <x:Boolean>True</x:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="syncOn" AutoReverse="False" RepeatBehavior="Forever">
            <DoubleAnimation Duration="0:0:0.4" To="360" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.Rotation)" Storyboard.TargetName="textBlock1" d:IsOptimized="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Duration="0:0:0.4" To="1" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="border" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.4" To="1" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="border" d:IsOptimized="True"/>
        </Storyboard>
        <Storyboard x:Name="realTime">
            <ColorAnimation Duration="0:0:0.2" To="#FF95B04C" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border" d:IsOptimized="True"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(TextBlock.Text)" Storyboard.TargetName="textBlock1">
                <DiscreteObjectKeyFrame KeyTime="0" Value="t"/>
            </ObjectAnimationUsingKeyFrames>
            <ColorAnimation Duration="0:0:0.2" To="White" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="textBlock1" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.3" To="0.65" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="border" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.3" To="0.65" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="border" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="0.8" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="textBlock1" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="0.75" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="textBlock1" d:IsOptimized="True"/>
        </Storyboard>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:DrawerLayout x:Name="SideBar" Grid.Row="1" Grid.Column="1">
            <Grid x:Name="MainFragment" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="grid3" Grid.Column="1" Grid.Row="1">
                        <Grid.Projection>
                            <PlaneProjection/>
                        </Grid.Projection>
                        <ListView x:Name="ExpenseView" 
                                  Grid.Row="1"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  SelectionMode="Extended"
                                  ItemTemplate="{StaticResource ExpenseListViewItemTemplate}" 
                                  ItemsPanel="{StaticResource ExpenseListViewItemsPanel}"
                                  ItemContainerStyle="{StaticResource ListViewItemContainerStyle}"
                                  Background="#FF9B5454" SelectionChanged="ExpenseSelectionChanged" />
                    </Grid>



                    <Grid x:Name="grid2" Grid.Row="1" >
                        <Grid.Projection>
                            <PlaneProjection/>
                        </Grid.Projection>
                        <Border Grid.Row="1">
                            <ListView 
                                x:Name="IncomeView" 
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              SelectionMode="Extended"
                              ItemTemplate="{StaticResource ExpenseListViewItemTemplate}" 
                                  Background="#FF95B04C" 
                                  ItemsPanel="{StaticResource ExpenseListViewItemsPanel}"
                                ItemContainerStyle="{StaticResource ListViewItemContainerStyle}"
                                SelectionChanged="IncomeSelectionChanged">
                                
                            </ListView>
                        </Border>
                    </Grid>
                    <Rectangle x:Name="rectangle" Fill="#7F383838" Grid.Row="1" Grid.ColumnSpan="2" Visibility="Collapsed" Opacity="0" Tapped="RectangleTapped"/>

                </Grid>
                <StackPanel x:Name="stackPanel2" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Background="White" RenderTransformOrigin="0.5,0.5" Opacity="0" Visibility="Collapsed">
                    <StackPanel.RenderTransform>
                        <CompositeTransform TranslateY="-60"/>
                    </StackPanel.RenderTransform>
                    <Button Content="Name" Foreground="Black" HorizontalAlignment="Center" Click="SortButtonIncome"/>
                    <Button Content="Date" Foreground="Black" HorizontalAlignment="Center" Click="SortButtonIncome"/>
                    <Button Content="Amount" Foreground="Black" HorizontalAlignment="Center" Click="SortButtonIncome"/>
                </StackPanel>
                <StackPanel x:Name="stackPanel3" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top" Background="White" RenderTransformOrigin="0.5,0.5" Opacity="0" Visibility="Collapsed">
                    <StackPanel.RenderTransform>
                        <CompositeTransform TranslateY="-60"/>
                    </StackPanel.RenderTransform>
                    <Button Content="Name" Foreground="Black" HorizontalAlignment="Center" Click="SortButtonExpense"/>
                    <Button Content="Date" Foreground="Black" HorizontalAlignment="Center" Click="SortButtonExpense"/>
                    <Button Content="Amount" Foreground="Black" HorizontalAlignment="Center" Click="SortButtonExpense"/>
                </StackPanel>




                <Grid x:Name="grid" Grid.Row="1" RenderTransformOrigin="0.5,0.5" Background="White" Opacity="0" Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <CompositeTransform TranslateY="-60"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <FlipView x:Name="flipView" Background="White" Style="{StaticResource FlipViewExpense}">

                        <FlipViewItem Background="White">
                            <Grid Margin="15,15,15,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="#FF95B04C" Text="INCOME" FontSize="24" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,20,0,0"/>
                                    <Rectangle Fill="#FF95B04C" Height="1" Margin="75,5,75,20"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="10,0" Text="AMOUNT" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF8E8E94"/>
                                        <TextBox x:Name="incomeTextBox" Grid.Column="1" TextChanged="AmountTextChanged" BorderBrush="{x:Null}" Margin="5,0,0,0" Background="#FFCDCDCD" InputScope="Number"/>
                                        <ComboBox Grid.Column="2">
                                            <ComboBoxItem>
                                                <TextBlock Text="{StaticResource Currency}"/>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <!--<Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.25*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>-->
                                    <GridView 
                                            Grid.Column="1"
                                        x:Name="gridIncomeType"
                                        CanDragItems="True"
                                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                                        ScrollViewer.VerticalScrollMode="Enabled"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.HorizontalScrollMode="Disabled"
                                        CanReorderItems="True"
                                        ItemTemplate="{StaticResource ExpenseGridViewTypeItemTemplate}" BorderThickness="0.5"
                                        ItemsPanel="{StaticResource GridTypeTemplate}"/>
                                </Grid>
                                <RichEditBox  Height="150" Grid.Row="2" x:Name="incomeDescription" PlaceholderText="type to enter..." Header="DESCRIPTION" Style="{StaticResource RichEditBoxStyleDefault}" Margin="0,10,0,0" SelectionHighlightColor="#FF2C2C2C" Background="{x:Null}" BorderBrush="#FFC7C7C7"/>
                            </Grid>
                        </FlipViewItem>
                        <FlipViewItem Background="White">
                            <Grid Margin="15,15,15,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="EXPENSE" FontSize="24" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,20,0,0" Foreground="#FFB83636"/>
                                    <Rectangle Fill="#FFC76161" Height="1" Margin="75,5,75,20"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="10,0" Text="AMOUNT" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF8E8E94"/>
                                        <TextBox x:Name="expenseTextBox" Grid.Column="1" TextChanged="AmountTextChanged" BorderBrush="{x:Null}" Margin="5,0,0,0" Background="#FFCDCDCD" InputScope="Number"/>
                                        <ComboBox Grid.Column="2">
                                            <ComboBoxItem>
                                                <TextBlock Text="{StaticResource Currency}"/>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <!--<Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.25*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>-->
                                    <GridView 
                                            Grid.Column="1"
                                        x:Name="gridExpenseType"
                                        CanDragItems="True"
                                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                                        ScrollViewer.VerticalScrollMode="Enabled"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.HorizontalScrollMode="Disabled"
                                        CanReorderItems="True"
                                        ItemTemplate="{StaticResource ExpenseGridViewTypeItemTemplate}" BorderThickness="0.5"
                                        ItemsPanel="{StaticResource GridTypeTemplate}"/>
                                </Grid>
                                <RichEditBox  Height="150" Grid.Row="2" x:Name="expenseDescription" PlaceholderText="type to enter..." Header="DESCRIPTION" Style="{StaticResource RichEditBoxStyleDefault}" Margin="0,10,0,0" SelectionHighlightColor="#FF2C2C2C" Background="{x:Null}" BorderBrush="#FFC7C7C7"/>
                            </Grid>
                        </FlipViewItem>
                    </FlipView>
                    <Grid Grid.Row="1" Background="#FF48A839">
                        <Button IsEnabled="False" x:Name="okButton" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FF48A839" Content="OK" BorderBrush="{x:Null}" Click="OKClick"/>
                    </Grid>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="stackPanel" Margin="0,15,0,0" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <CompositeTransform/>
                        </StackPanel.RenderTransform>
                        <TextBlock Margin="5" MinHeight="0" Foreground="Black" HorizontalAlignment="Center" FontWeight="Thin" Text="INCOME" FontSize="20"/>
                        <TextBlock FontSize="26.667" HorizontalAlignment="Center" Foreground="Black" FontWeight="SemiLight">
                    	<Run Text="{StaticResource Currency}"/>
                    	<Run Text="10,45,053"/>
                        </TextBlock>
                        <Grid x:Name="grid6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:WatermarkTextBox x:Name="watermarkTextBox"  Grid.Column="1" WatermarkText="⌕ type to search..." VerticalAlignment="Center" Background="White" Foreground="Black"/>
                            <ToggleButton x:Name="leftToggleBtn" MinHeight="0" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" Content="F" Foreground="#FF007ACC" Checked="LeftSortChecked" Unchecked="LeftSortUnchecked"/>
                            <Grid x:Name="grid4" Grid.ColumnSpan="2" Background="White" Opacity="0" IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="d" HorizontalAlignment="Stretch" Click="LDeleteButtonClick" Foreground="#FF9B5454" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" FontSize="24"/>
                                <Button Grid.Column="1" Content="E" HorizontalAlignment="Stretch" Click="LEditButtonClick" Foreground="#FF007ACC" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" FontSize="24"/>
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="stackPanel1" Grid.Column="2" Margin="0,15,0,0" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <CompositeTransform/>
                        </StackPanel.RenderTransform>
                        <TextBlock Margin="5" MinHeight="0" Foreground="Black" HorizontalAlignment="Center" FontWeight="Thin" Text="EXPENSE" FontSize="20"/>
                        <TextBlock FontSize="26.667" HorizontalAlignment="Center" Foreground="Black" FontWeight="SemiLight">
                    	<Run Text="{StaticResource Currency}"/>
                    	<Run Text="5,70,000"/>
                        </TextBlock>
                        <Grid x:Name="grid7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:WatermarkTextBox x:Name="watermarkTextBox1" WatermarkText="⌕ type to search..." VerticalAlignment="Center" Background="White" Foreground="Black"/>
                            <ToggleButton x:Name="rightToggleBtn" MinHeight="0" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" Grid.Column="1" Content="F" Foreground="#FF007ACC" Checked="RightSortChecked" Unchecked="RightSortUnchecked"/>
                            <Grid x:Name="grid5" Grid.ColumnSpan="2" Background="White" Opacity="0" IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="d" HorizontalAlignment="Stretch" Click="RDeleteButtonClick" Foreground="#FF9B5454" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" FontSize="24"/>
                                <Button Grid.Column="1" Content="E" HorizontalAlignment="Stretch" Click="REditButtonClick" Foreground="#FF007ACC" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" FontSize="24"/>
                            </Grid>
                        </Grid>
                    </StackPanel>


                    <ToggleButton Grid.Column="1" x:Name="toggleButton" VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="{x:Null}" BorderBrush="{x:Null}" Checked="OpenTans" Unchecked="CloseTrans" Holding="OpenRapidTrans">
                        <ToggleButton.RenderTransform>
                            <CompositeTransform TranslateY="25"/>
                        </ToggleButton.RenderTransform>
                        <Grid x:Name="grid1" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <CompositeTransform/>
                            </Grid.RenderTransform>
                            <Ellipse x:Name="ellipse" Width="75" Height="75" Fill="White" RenderTransformOrigin="0.5,0.5"/>
                            <TextBlock x:Name="textBlock" Text="+" Foreground="Black" FontSize="53.333" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" OpticalMarginAlignment="TrimSideBearings" TextLineBounds="Tight" RenderTransformOrigin="0.5,0.5" >
                                <TextBlock.RenderTransform>
                                    <CompositeTransform/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </ToggleButton>

                </Grid>
            </Grid>
            <Grid Width="40" IsHitTestVisible="False" HorizontalAlignment="Left" Grid.Row="1"/>
            <Grid Width="0" x:Name="ListFragment" Grid.Row="1" HorizontalAlignment="Left" Background="White">
                <Frame x:Name="MenuFrame" Grid.Row="1"/>
            </Grid>
        </local:DrawerLayout>

        <Grid Grid.Row="1" Background="#FFE8E8E8" >
            <!-- BUGGY!!!.....PointerWheelChanged="SideBarPointerWheel"-->
            <Border Background="#FFC12525" Height="20" Width="20" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,45,10,0">
                <TextBlock Text="3" Margin="2" FontSize="10.667" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel>
                <Button Content="D" FontSize="25" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" MinWidth="0" Click="OpenDashboard" Foreground="Black" FontWeight="Thin" HorizontalAlignment="Center" Height="75"/>
                <Button Content="L" Foreground="Black" MinWidth="60" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" Click="OpenList" HorizontalAlignment="Center" Height="75"/>
                <Button Content="C" Foreground="Black" MinWidth="60" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" Click="OpenCalendar" HorizontalAlignment="Center" Height="75"/>
                <Button Content="U" Foreground="Black" MinWidth="60" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" Click="OpenSalaryList" HorizontalAlignment="Center" Height="75"/>
                <Button MinWidth="60" Content="S" Foreground="Black" FontWeight="Thin" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" Click="OpenSettings" HorizontalAlignment="Center" Height="75"/>
            </StackPanel>
            <Rectangle x:Name="menuIndicator" Height="75" Width="4" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#FF007ACC" Margin="0,75,0,0"/>
            <CheckBox x:Name="checkBox" Checked="checkBox_Checked" Unchecked="checkBox_Unchecked" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,75"/>
            <Border x:Name="border" Background="White" Height="40" Width="40" CornerRadius="256" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform/>
                </Border.RenderTransform>
                <TextBlock x:Name="textBlock1" Text="s" Margin="2" FontSize="26.667" Foreground="#FF007ACC" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Fonts/Iconographics/expensemanagerui.ttf#expensemanagerui" FontWeight="Thin" TextAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <CompositeTransform/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Border>
        </Grid>
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#CC000000">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="2" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
