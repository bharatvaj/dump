    <cell>ஃ</cell>
    <cell>அ</cell>
     <p>pronounced is a short "a" , or to be more precise "u" in "uncle"</p>
    <cell>ஆ</cell>
     <p>pronounced is a long "aa" , Example: "a" in "father"</p>
    <cell>இ</cell>
     <p>pronounced as a short "i" , Example: "i" in "it"</p>
    <cell>ஈ</cell>
     <p>pronounced as long "ii", Example: "Ee" in "bee"</p>
    <cell>உ</cell>
     <p>pronounced as short "u", Example: "u" in "put"</p>
    <cell>ஊ</cell>
     <p>pronounced as long "u", Example: "u" in "puma"</p>
    <cell>எ</cell>
     <p>pronounced as short "e", Example: "e" in "let"</p>
    <cell>ஏ</cell>
     <p>pronounced as long "e", Example: "a" in "ate"</p>
    <cell>ஐ</cell>
     <p>pronounced as the english letter "I", Example: "eye" as in "eye" itsely</p>
    <cell>ஒ</cell>
     <p>pronouced as short "o", Example: "o", Example: "o" in "poke" (not "ow" but rather a crisp "o")</p>
    <cell>ஓ</cell>
     <p>pronounced as long "o", Example: "o", Example: "o" in "fort"</p>
    <cell>ஔ</cell>
     <p>pronounced as "ow", as in "Powder"</p>
