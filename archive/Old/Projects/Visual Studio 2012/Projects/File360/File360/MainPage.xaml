<phone:PhoneApplicationPage
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ExpInteractivity="clr-namespace:Microsoft.Expression.Interactivity.Layout;assembly=Microsoft.Expression.Interactions"
    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity" xmlns:ec="clr-namespace:Microsoft.Expression.Interactivity.Core;assembly=Microsoft.Expression.Interactions"
    xmlns:local="clr-namespace:File360"
    xmlns:Controls="clr-namespace:Microsoft.Live.Controls;assembly=Microsoft.Live.Controls"
    xmlns:metro="clr-namespace:MetroInMotionUtils"
    xmlns:System="clr-namespace:System;assembly=mscorlib"
    xmlns:es="clr-namespace:Microsoft.Expression.Shapes;assembly=Microsoft.Expression.Drawing"
    x:Class="File360.MainPage"
    Orientation="Portrait"
    mc:Ignorable="d"
    shell:SystemTray.IsVisible="False">

    <phone:PhoneApplicationPage.Resources>
        <!--DataTemplate-->
        <DataTemplate x:Name="File360FileTemplate">
            <Grid Hold="folderTap_Hold" Tap="folderTap_Click" Height="120" Width="110" VerticalAlignment="Bottom" HorizontalAlignment="Right" Background="{x:Null}">
                <StackPanel>
                    <Rectangle Height="10" VerticalAlignment="Top"/>
                    <Rectangle Width="115" Height="70" VerticalAlignment="Top">
                        <Rectangle.Fill>
                            <ImageBrush Stretch="Uniform" ImageSource="{Binding Name2}"/>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock x:Name="folderTap" TextWrapping="NoWrap" TextTrimming="WordEllipsis" Text="{Binding Name}" TextAlignment="Center" FontFamily="Segoe UI Light" FontSize="20" Height="30" Foreground="{StaticResource PhoneForegroundBrush}" Width="115" VerticalAlignment="Top"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Name="SettingsItemTemplate">
            <Grid Tap="SettingTap_Tap" x:Name="SettingTap" Height="120">
                <TextBlock x:Name="txtB" Margin="116,10,10,48" Foreground="{StaticResource PhoneForegroundBrush}" Text="{Binding SettingName}" FontSize="36"/>
                <TextBlock Margin="111,65,17,20" Foreground="{StaticResource PhoneSubtleBrush}" Text="{Binding SettingDescription}" FontFamily="Segoe UI Light"/>
                <Rectangle HorizontalAlignment="Left" Height="75" Margin="6,24,0,0" Stroke="{x:Null}" VerticalAlignment="Top" Width="75" Fill="{StaticResource PhoneForegroundBrush}">
                    <Rectangle.OpacityMask>
                        <ImageBrush Stretch="Uniform" ImageSource="{Binding SettingPicture}"/>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Name="MusicItemTemplate">
            <Grid Height="100" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding SONG}"  HorizontalAlignment="Left" Height="40" Margin="38,20,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="373" Foreground="#FFFFFFFF" FontSize="28" FontFamily="Segoe WP Light"/>
                <TextBlock Text="{Binding ARTIST}" HorizontalAlignment="Left" Height="30" Margin="38,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="374" FontSize="22" FontFamily="Segoe wp Light" Foreground="#BFFFFFFF"/>
            </Grid>
        </DataTemplate>

        <!--StoryBoard-->
        <Storyboard x:Name="expandAnimation">
            <DoubleAnimation Storyboard.TargetName="searchButton" Storyboard.TargetProperty="Width" To="75" Duration="0:0:0.1"/>
            <DoubleAnimation Storyboard.TargetName="searchBox" Storyboard.TargetProperty="Width" From="247" To="200" Duration="0:0:0.1"/>
        </Storyboard>
        <Storyboard x:Name="headerExpandAnimation">
            <DoubleAnimation Storyboard.TargetName="header" Storyboard.TargetProperty="Height" To="518" Duration="0:0:0.2"/>
            <DoubleAnimation Duration="0:0:0.2" To="-1" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="180" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.Rotation)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="-19.952" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
            <ColorAnimation Duration="0:0:0.2" To="{StaticResource PhoneBackgroundColor}" Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
        </Storyboard>
        <Storyboard x:Name="headerShrinkAnimation">
            <DoubleAnimation Storyboard.TargetName="header" Storyboard.TargetProperty="Height" To="91" Duration="0:0:0.2"/>
            <ColorAnimation Duration="0:0:0.2" To="{StaticResource PhoneForegroundColor}" Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="1" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="180" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.Rotation)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="0" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)" Storyboard.TargetName="posI" d:IsOptimized="True"/>
        </Storyboard>
        <Storyboard x:Name="shrinkAnimation">
            <DoubleAnimation Storyboard.TargetName="searchButton" Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="searchBox" Storyboard.TargetProperty="Width" From="200" To="247" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Name="downladAnimation">
            <DoubleAnimation Storyboard.TargetName="downloadProgress" Storyboard.TargetProperty="Width" From="65" To="45" Duration="0:0:0.2" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
        <Storyboard x:Name="slideInPictureGrid">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)" Storyboard.TargetName="ptc">
                <EasingDoubleKeyFrame KeyTime="0" Value="10.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="-422.5"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="aboutAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="fal">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="2.477"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="2.665"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="fal">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="2.477"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="2.665"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)" Storyboard.TargetName="fal">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="180.75"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="186.75"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)" Storyboard.TargetName="fal">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="116.25"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="99.75"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="fal">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0.35"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimation Duration="0:0:0.3" To="360" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.Rotation)" Storyboard.TargetName="fal" d:IsOptimized="True"/>
        </Storyboard>
        <Storyboard x:Name="settingPopup">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="settings">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="settings">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="grid1">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.32" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="aboutPage">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(Popup.IsOpen)" Storyboard.TargetName="about">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <System:Boolean>True</System:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="about">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="about">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="about">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="personalizationPage">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(Popup.IsOpen)" Storyboard.TargetName="personalization">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <System:Boolean>True</System:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="grid2">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="grid2">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="personalization">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="securityPage">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(Popup.IsOpen)" Storyboard.TargetName="security">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <System:Boolean>True</System:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)" Storyboard.TargetName="security">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)" Storyboard.TargetName="security">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="security">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="blurer">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="Blurer">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="mediaBackgroundFade">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="RightMediaMenu">
                <EasingDoubleKeyFrame KeyTime="0" Value="0.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="ringRotate">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Arc.EndAngle)" Storyboard.TargetName="arcs">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Arc.EndAngle)" Storyboard.TargetName="arcbg">
                <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Name="slideRight">
            <ColorAnimation Duration="0:0:0.2" To="{StaticResource PhoneForegroundColor}" Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="button" d:IsOptimized="True"/>
        </Storyboard>

        <Storyboard x:Name="dragMusic">
            <DoubleAnimation Duration="0:0:0.2" To="450" Storyboard.TargetProperty="(FrameworkElement.Height)" Storyboard.TargetName="grid" d:IsOptimized="True"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(FrameworkElement.VerticalAlignment)" Storyboard.TargetName="grid">
                <DiscreteObjectKeyFrame KeyTime="0">
                    <DiscreteObjectKeyFrame.Value>
                        <VerticalAlignment>Bottom</VerticalAlignment>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <ColorAnimation Duration="0:0:0.2" To="{StaticResource PhoneAccentColor}" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="textBlock" d:IsOptimized="True"/>
            <ColorAnimation Duration="0:0:0.2" To="{StaticResource PhoneForegroundColor}" Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="toggleButton" d:IsOptimized="True"/>
            <ColorAnimation Duration="0:0:0.2" To="{StaticResource PhoneAccentColor}" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="textBlock1" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="300" Storyboard.TargetProperty="(FrameworkElement.Height)" Storyboard.TargetName="musicLists" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="1" Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="musicCoverArt" d:IsOptimized="True"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.IsHitTestVisible)" Storyboard.TargetName="LayoutRoot">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.2">
                    <DiscreteObjectKeyFrame.Value>
                        <System:Boolean>True</System:Boolean>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Duration="0:0:0.2" To="800" Storyboard.TargetProperty="(FrameworkElement.Height)" Storyboard.TargetName="playStateGrid" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.2" To="4.501" Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)" Storyboard.TargetName="canvas" d:IsOptimized="True"/>
        </Storyboard>

        <Storyboard x:Name="holdMenu">
            <DoubleAnimation Duration="0:0:0.15" To="95" Storyboard.TargetProperty="(FrameworkElement.Height)" Storyboard.TargetName="holdMenuGrid" d:IsOptimized="True"/>
            <DoubleAnimation Duration="0:0:0.15" To="605" Storyboard.TargetProperty="(FrameworkElement.Height)" Storyboard.TargetName="sdlists" d:IsOptimized="True"/>
        </Storyboard>

        <!--Other Resources-->
        <ImageBrush x:Name="folderim" Stretch="Uniform" ImageSource="/Resources/Assets/Images/folder.png"/>

    </phone:PhoneApplicationPage.Resources>

    <Canvas x:Name="canvas" HorizontalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
        <Canvas.Resources>
            <Storyboard x:Name="moveAnimation">
                <DoubleAnimation Duration="0:0:0.2" To="0" Storyboard.TargetProperty="(Canvas.Left)" Storyboard.TargetName="LayoutRoot" d:IsOptimized="True" />
            </Storyboard>
        </Canvas.Resources>
        <Canvas.RenderTransform>
            <CompositeTransform/>
        </Canvas.RenderTransform>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="VisualStateGroup">
                <VisualStateGroup.Transitions>
                    <VisualTransition GeneratedDuration="0"/>
                </VisualStateGroup.Transitions>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Canvas CacheMode="BitmapCache" x:Name="LayoutRoot" ManipulationStarted="canvas_ManipulationStarted" ManipulationDelta="canvas_ManipulationDelta" ManipulationCompleted="canvas_ManipulationCompleted" Width="1740"  VerticalAlignment="Bottom" Canvas.Left="-420" Height="800" Background="{StaticResource PhoneBackgroundBrush}">
            <Popup x:Name="about" Height="800" Width="480">
                <Popup.RenderTransform>
                    <CompositeTransform/>
                </Popup.RenderTransform>
                <Popup.Projection>
                    <PlaneProjection/>
                </Popup.Projection>
                <Grid Height="800" Width="480">
                    <Grid Margin="10,20,10,20">
                        <Rectangle x:Name="bgChanger" Stroke="{StaticResource PhoneForegroundBrush}" StrokeThickness="3" Fill="{StaticResource PhoneChromeBrush}" RadiusX="10" RadiusY="10"/>
                        <Image HorizontalAlignment="Center" Height="91" Margin="0,431,0,0" VerticalAlignment="Top" Source="/AMI.png" Width="294"/>
                        <HyperlinkButton Content="am Industries inc." HorizontalAlignment="Center" Margin="0,540,0,0" VerticalAlignment="Top" FontFamily="Segoe WP Light" Foreground="{StaticResource PhoneForegroundBrush}"/>
                        <TextBlock HorizontalAlignment="Left" Margin="28,378,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="30" Text="developed &amp; produced by" Foreground="{StaticResource PhoneForegroundBrush}" FontFamily="Segoe WP Light" FontSize="18"/>
                        <Rectangle x:Name="blue" HorizontalAlignment="Left" Height="100" Margin="286,422,0,0" VerticalAlignment="Top" Width="75"/>
                        <Rectangle x:Name="red" HorizontalAlignment="Left" Height="100" Margin="105,422,0,0" VerticalAlignment="Top" Width="75"/>
                        <Rectangle x:Name="green" HorizontalAlignment="Left" Height="100" Margin="196,422,0,0" VerticalAlignment="Top" Width="75"/>
                        <TextBlock HorizontalAlignment="Left" Height="60" Margin="28,32,0,0" TextWrapping="Wrap" Text="about" VerticalAlignment="Top" Width="276" FontSize="40" FontFamily="Segoe WP Light" Foreground="{StaticResource PhoneForegroundBrush}"/>
                        <Rectangle Visibility="Visible" x:Name="fal" HorizontalAlignment="Left" Height="75" Margin="10,28,0,0" VerticalAlignment="Top" Width="75" Fill="{StaticResource PhoneForegroundBrush}" Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <CompositeTransform/>
                            </Rectangle.RenderTransform>
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="/FILE360.png" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock HorizontalAlignment="Center" Height="98" Margin="0,275,0,0" TextWrapping="Wrap" Text="thankyou for purchasing FILE360 and supporting AMI. This is a premium version." VerticalAlignment="Top" Width="440" FontFamily="Segoe WP Light" FontSize="22" Foreground="{StaticResource PhoneForegroundBrush}" TextAlignment="Center"/>
                        <HyperlinkButton Content="rate &amp; review application" HorizontalAlignment="Center" Margin="0,608,0,0" VerticalAlignment="Top" FontFamily="Segoe WP Light" Foreground="{StaticResource PhoneForegroundBrush}"/>
                    </Grid>
                </Grid>
            </Popup>
            <Popup x:Name="security" Height="800" Width="480" RenderTransformOrigin="0.5,0.5">
                <Popup.RenderTransform>
                    <CompositeTransform/>
                </Popup.RenderTransform>
                <Grid Height="800" Width="480">
                    <Grid Margin="10,20,10,20">
                        <Rectangle Stroke="{StaticResource PhoneForegroundBrush}" StrokeThickness="3" Fill="{StaticResource PhoneChromeBrush}" RadiusX="10" RadiusY="10"/>
                        <toolkit:ToggleSwitch x:Name="passw" Checked="passw_Checked" Unchecked="passw_Unchecked" HorizontalAlignment="Left" Margin="10,148,0,0" VerticalAlignment="Top" Width="420" Content="password"/>
                        <toolkit:ToggleSwitch x:Name="shake" Checked="shake_Checked" Unchecked="shake_Unchecked" HorizontalAlignment="Left" Margin="10,256,0,0" VerticalAlignment="Top" Width="420" Content="shake to hide"/>
                        <TextBox x:Name="pb" HorizontalAlignment="Left" Height="84" Margin="10,359,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="420" TextChanged="PSetter" Foreground="{StaticResource PhoneBackgroundBrush}" SelectionBackground="{x:Null}" SelectionForeground="{x:Null}"/>
                        <TextBlock HorizontalAlignment="Left" Height="81" Margin="16,31,0,0" TextWrapping="Wrap" Text="security" VerticalAlignment="Top" Width="378" Foreground="{StaticResource PhoneForegroundBrush}" FontFamily="Segoe WP Light" FontSize="40"/>
                    </Grid>
                </Grid>
            </Popup>
            <Popup x:Name="personalization" Height="800" Width="480">
                <Popup.RenderTransform>
                    <CompositeTransform/>
                </Popup.RenderTransform>
                <Grid x:Name="grid2" Height="800" Width="480" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <CompositeTransform/>
                    </Grid.RenderTransform>
                    <Grid Margin="10,20,10,20">
                        <Rectangle Stroke="{StaticResource PhoneForegroundBrush}" StrokeThickness="3" RadiusY="10" RadiusX="10" Fill="{StaticResource PhoneChromeBrush}"/>
                        <TextBlock Margin="22,21,2,609" Style="{StaticResource PhoneTextTitle1Style}" Text="personalization" FontSize="40" FontFamily="Segoe WP Light"/>
                        <ListBox x:Name="listBox" Margin="10,84,0,0">
                            <toolkit:ToggleSwitch x:Name="Wallpaper" Checked="Wallpaper_Checked" Unchecked="Wallpaper_Unchecked" Content="Wallpaper" Width="420" Height="108"/>
                            <Grid x:Name="WallpaperTemp" Visibility="Visible" Height="341" Width="420">
                                <Rectangle x:Name="SideMenuWallChanger" Margin="10,0,10,59" RadiusY="23.5" RadiusX="23.5">
                                    <Rectangle.Fill>
                                        <ImageBrush Stretch="Uniform" ImageSource="/Resources/Assets/Wallpaper/bg1.jpg"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle Fill="{StaticResource PhoneDisabledBrush}" Margin="0,318,0,17" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <CompositeTransform ScaleY="-1"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <TextBlock Tap="SideMenuWallChanger_Tap"  HorizontalAlignment="Left" Height="59" Margin="141,272,0,0" VerticalAlignment="Top" Width="115" Text="change" FontSize="36" FontFamily="Segoe WP Light">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <GradientStop Color="#99FFFFFF" Offset="0"/>
                                            <GradientStop Color="#BFFFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Grid>
                            <toolkit:ToggleSwitch Content="Sound FX" Width="420" Height="104"/>
                            <Grid Width="470">
                                <TextBlock TextWrapping="Wrap" Text="Sidebar Color" FontFamily="Segoe WP Light" FontSize="30" Margin="10,4,268,6"/>
                            </Grid>
                        </ListBox>
                    </Grid>
                </Grid>
            </Popup>

            <Grid x:Name="grdCommands" CacheMode="BitmapCache" Height="800" Width="480" Canvas.Left="420" Background="{StaticResource PhoneBackgroundBrush}" >
                <Popup x:Name="PasswordAccepter">
                    <Grid Height="800" Width="480" Background="{StaticResource PhoneBackgroundBrush}">
                        <Grid Margin="0,0,0,603">
                            <TextBlock x:Name="passwordDisplay" VerticalAlignment="Center" HorizontalAlignment="Left" Height="72" Margin="51,16,0,9" TextWrapping="Wrap" Width="384" FontSize="48" TextAlignment="Center" Foreground="{StaticResource PhoneForegroundBrush}"/>
                        </Grid>
                        <toolkit:WrapPanel x:Name="wrapPanel" Margin="10,102,10,187" Height="307.5"/>
